@page "/"
@using PersonalGardenLog.Models
@using PersonalGardenLog.Data
@using Microsoft.EntityFrameworkCore
@inject GardenDbContext DbContext
@inject ISnackbar Snackbar

<MudText Typo="Typo.h3" Color="Color.Primary" Class="mb-4">🌿 Personal Garden Log</MudText>

<MudGrid>
    <MudItem xs="12" md="7">
        <MudCard Elevation="3">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5">My Plants</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @if (plants == null)
                {
                    <MudProgressCircular Color="Color.Default" Indeterminate="true" />
                }
                else if (!plants.Any())
                {
                    <MudText Typo="Typo.body1" Color="Color.Secondary">No plants registered yet. Add one from the form!</MudText>
                }
                else
                {
                    <MudList T="string">
                        @foreach (var plant in plants)
                        {
                            <MudListItem T="string" Icon="@Icons.Material.Filled.LocalFlorist" IconColor="@(plant.IsUrgent ? Color.Error : Color.Success)">
                                <div class="d-flex align-center justify-space-between w-100">
                                    <div>
                                        <MudText Typo="Typo.h6">@plant.Name <MudChip T="string" Size="Size.Small" Color="Color.Info">@plant.Species</MudChip></MudText>
                                        <MudText Typo="Typo.body2">Interval: every @plant.WateringIntervalDays days</MudText>
                                        <MudText Typo="Typo.body2" Color="@(plant.IsUrgent ? Color.Error : Color.Default)">
                                            Next Watering: @plant.NextWateringDate.ToString("yyyy/MM/dd") 
                                            @(plant.IsUrgent ? "⚠️ Needs watering!" : "")
                                        </MudText>
                                    </div>
                                    <div>
                                        <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.WaterDrop" Class="mr-2" OnClick="() => WaterPlant(plant)">
                                            Watered
                                        </MudButton>
                                        <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete" OnClick="() => DeletePlant(plant)">
                                            Delete
                                        </MudButton>
                                    </div>
                                </div>
                            </MudListItem>
                            <MudDivider />
                        }
                    </MudList>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="5">
        <MudCard Elevation="3">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h5">🆕 Add New Plant</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <EditForm Model="@newPlant" OnValidSubmit="SavePlant">
                    <DataAnnotationsValidator />
                    
                    <MudTextField Label="Plant Name" @bind-Value="newPlant.Name" For="@(() => newPlant.Name)" Required="true" Class="mb-3" />
                    <MudTextField Label="Species/Category" @bind-Value="newPlant.Species" Class="mb-3" />
                    <MudNumericField Label="Watering Interval (days)" @bind-Value="newPlant.WateringIntervalDays" For="@(() => newPlant.WateringIntervalDays)" Min="1" Class="mb-4" />

                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Add">
                        Add to Garden
                    </MudButton>
                </EditForm>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

<MudThemeProvider />
<MudSnackbarProvider />

@code {
    private List<Plant>? plants;
    private Plant newPlant = new();

    protected override async Task OnInitializedAsync()
    {
        await DbContext.Database.EnsureCreatedAsync();
        await LoadPlants();
    }

    private async Task LoadPlants()
    {
        var rawList = await DbContext.Plants.ToListAsync();
        plants = rawList.OrderBy(p => p.NextWateringDate).ToList();
    }

    private async Task WaterPlant(Plant plant)
    {
        plant.LastWateredDate = DateTime.Now;
        DbContext.Plants.Update(plant);
        await DbContext.SaveChangesAsync();
        await LoadPlants();
        Snackbar.Add($"Recorded watering for {plant.Name}!", Severity.Success);
    }

    private async Task SavePlant()
    {
        newPlant.LastWateredDate = DateTime.Now;
        DbContext.Plants.Add(newPlant);
        await DbContext.SaveChangesAsync();
        
        newPlant = new Plant(); 
        await LoadPlants();
        Snackbar.Add("New plant added!", Severity.Success);
    }

    private async Task DeletePlant(Plant plant)
    {
        DbContext.Plants.Remove(plant);
        await DbContext.SaveChangesAsync();
        await LoadPlants();
        Snackbar.Add($"Deleted {plant.Name}.", Severity.Warning);
    }
}